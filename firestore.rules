rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || (
            request.auth.token.email_verified == true
            && request.auth.token.email in ["rso10041@gmail.com", "djmonnar4@gmail.com"]
          )
        );
    }

    match /admins/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /members/{userId} {
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "uid",
          "name",
          "birthDate",
          "phone",
          "address",
          "partyMember",
          "email",
          "providerEmail",
          "provider",
          "consent",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.name is string
        && (
          !request.resource.data.keys().hasAny(["birthDate"])
          || request.resource.data.birthDate.matches("^[0-9]{6}$")
        )
        && request.resource.data.phone is string
        && request.resource.data.address is string
        && request.resource.data.email is string
        && request.resource.data.provider == "google"
        && request.resource.data.partyMember in ["yes", "no", "prefer_not_to_say"]
        && request.resource.data.consent.privacy == true
        && request.resource.data.consent.politicalInfo == true;

      allow read: if isOwner(userId) || isAdmin();
    }

    match /proposals/{proposalId} {
      allow create: if signedIn()
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.private == true
        && request.resource.data.status == "접수"
        && request.resource.data.keys().hasOnly([
          "uid",
          "title",
          "category",
          "content",
          "status",
          "private",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.category is string
        && request.resource.data.content is string;

      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /newsPosts/{postId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "title",
          "category",
          "summary",
          "content",
          "published",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.category is string
        && request.resource.data.summary is string
        && request.resource.data.content is string
        && request.resource.data.published is bool;
      allow delete: if isAdmin();
    }

    match /albumPosts/{postId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "title",
          "caption",
          "imageUrl",
          "storagePath",
          "published",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.caption is string
        && request.resource.data.imageUrl is string
        && request.resource.data.storagePath is string
        && request.resource.data.published is bool;
      allow delete: if isAdmin();
    }

    match /mapActivities/{postId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "title",
          "category",
          "district",
          "date",
          "summary",
          "image",
          "storagePath",
          "lat",
          "lng",
          "sourceUrl",
          "sourceName",
          "sourceType",
          "status",
          "published",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.category in ["현장방문", "민원", "정책", "예산", "입법", "일정"]
        && request.resource.data.district is string
        && request.resource.data.date.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$")
        && request.resource.data.summary is string
        && request.resource.data.image is string
        && (
          !request.resource.data.keys().hasAny(["storagePath"])
          || request.resource.data.storagePath is string
        )
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.sourceUrl is string
        && request.resource.data.sourceName is string
        && request.resource.data.sourceType in ["official", "press"]
        && request.resource.data.status is string
        && request.resource.data.published is bool;
      allow delete: if isAdmin();
    }
  }
}
